@model HaberSitesi.Models.Haber

@{
    ViewData["Title"] = Model.Baslik;
}

<div class="container-fluid mt-5 mb-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="position-relative mb-3">
                    <div class="d-flex mb-3">
                        <a class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2" href="">
                            @Model.Kategori?.Ad
                        </a>
                        <a class="text-body" href="">@Model.Tarih.ToString("dd MMM yyyy")</a>
                    </div>
                    <h1 class="mb-3 text-secondary text-uppercase font-weight-bold">@Model.Baslik</h1>
                </div>

                <div class="mb-5">
                    <img class="img-fluid w-100 rounded" src="~/img/@Model.ResimYolu" style="object-fit: cover;">
                </div>

                <div class="mb-5">
                    <p style="font-size: 18px; line-height: 1.8;">
                        @Model.Icerik
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="mb-3">
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold">Reklam Alanı</h4>
                    </div>
                    <div class="bg-white text-center border border-top-0 p-3">
                        <a href=""><img class="img-fluid" src="~/img/news-800x500-2.jpg" alt=""></a>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <div class="section-title mb-0">
                    <h4 class="m-0 text-uppercase font-weight-bold">Yorumlar</h4>
                </div>
                <div class="bg-white border border-top-0 p-4">

                    @if (ViewBag.Yorumlar != null)
                    {
                        foreach (var yorum in ViewBag.Yorumlar)
                        {
                            <div class="media mb-4">
                                <div class="media-body">
                                    <h6>@yorum.AdSoyad <small><i>@yorum.Tarih.ToString("dd MMM yyyy HH:mm")</i></small></h6>
                                    <p>@yorum.Icerik</p>
                                </div>
                            </div>
                            <hr />
                        }
                    }

                    <h4 class="text-uppercase font-weight-bold mb-3">Yorum Yap</h4>
                    <form action="/Home/YorumYap" method="post">
                        <input type="hidden" name="HaberId" value="@Model.Id" />
                        <div class="form-group">
                            <label>Adınız</label>
                            <input type="text" name="AdSoyad" class="form-control form-control-lg" required>
                        </div>
                        <div class="form-group">
                            <label>Yorumunuz</label>
                            <textarea name="Icerik" rows="5" class="form-control form-control-lg" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary font-weight-semi-bold py-2 px-3">Gönder</button>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>