@using HaberSitesi.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>BAHO NEWS| Gündem</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.theme.default.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-color: #0056b3;
            --accent-color: #ff3e3e;
            --dark-bg: #111827;
            --text-color: #374151;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
            color: var(--text-color);
        }

        .navbar {
            backdrop-filter: blur(10px);
            background-color: rgba(255, 255, 255, 0.95) !important;
        }

        .brand-text {
            letter-spacing: -1px;
            font-weight: 800;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light fixed-top shadow-sm py-3">
        <div class="container">
            <a href="/" class="navbar-brand d-flex align-items-center">
                <span class="fs-3 brand-text text-dark">BAHO</span>
                <span class="fs-3 brand-text text-danger">NEWS</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-semibold text-uppercase fs-6">
                    <li class="nav-item"><a href="/" class="nav-link px-3 text-dark">Gündem</a></li>

                    <li class="nav-item">
                        @await Component.InvokeAsync("KategoriMenu")
                    </li>

                    <li class="nav-item"><a href="/Home/Iletisim" class="nav-link px-3 text-dark">İletişim</a></li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item ms-lg-3"><a href="/Haber" class="btn btn-dark btn-sm rounded-pill px-3">Panel</a></li>
                    }
                </ul>

                <div class="ms-lg-4 d-flex align-items-center border-start ps-lg-4 mt-3 mt-lg-0">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown">
                            <button class="btn btn-link text-dark text-decoration-none dropdown-toggle fw-bold" data-bs-toggle="dropdown">
                                @User.Identity.Name
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item text-danger" href="/Guvenlik/Logout">Çıkış</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Guvenlik/Login" class="text-dark fw-bold text-decoration-none me-3">Giriş</a>
                        <a href="/Guvenlik/Register" class="btn btn-danger rounded-pill px-4 btn-sm fw-bold">Kayıt Ol</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div style="margin-top: 100px;">
        @RenderBody()
    </div>

    <footer class="bg-dark text-white mt-auto pt-5 pb-4">
        <div class="container">
            <div class="row g-4 justify-content-between">
                <div class="col-md-4">
                    <h5 class="fw-bold mb-3">BAHO NEWS</h5>
                    <p class="text-secondary small">Dünyadan ve Türkiye'den en sıcak gelişmeleri anlık olarak takip edin.</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <a href="#" class="text-white-50"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-youtube"></i></a>
                    </div>
                    <p class="small text-secondary mt-3 mb-0">&copy; @DateTime.Now.Year Tüm Hakları Saklıdır.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>