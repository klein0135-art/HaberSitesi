 sonra cesedinin tel \u00f6rg\u00fc ve ta\u015fa sar\u0131larak K\u0131z\u0131l\u0131rmak'a at\u0131lmas\u0131yla ilgili yarg\u0131lanan 2 san\u0131k, ayr\u0131 ayr\u0131 a\u011f\u0131rla\u015ft\u0131r\u0131lm\u0131\u015f m\u00fcebbet ve 8 y\u0131l 12'\u015fer ay hapis cezas\u0131na \u00e7arpt\u0131r\u0131ld\u0131","slug":"cesedi-tasa-sarilip-kizilirmak-a-atilmisti-2-caniye-ceza-yagdi-son-dakika-haber","writer":"","category":{"type":"category","items":[{"id":110,"name":"G\u00fcndem","url":"\/gundem","appUrl":"cbg:\/\/haber\/kategori\/ht\/gundem"},{"id":4060590,"name":"3. Sayfa","url":"\/gundem\/ucuncu-sayfa","appUrl":"cbg:\/\/haber\/kategori\/ht\/gundem\/ucuncu-sayfa"}]},"url":"\/cesedi-tasa-sarilip-kizilirmak-a-atilmisti-2-caniye-ceza-yagdi-son-dakika-haber-3854563","appUrl":"cbg:\/\/haber\/detay\/3854563","ampUrl":"\/cesedi-tasa-sarilip-kizilirmak-a-atilmisti-2-caniye-ceza-yagdi-son-dakika-haber-3854563-amp","newsMetaData":{"textColor":"text-white","appTextColor":"white","newsDetailType":"type1","headline":"","emoji":0,"specialColor":"","specialColorText":""},"fastLinkText":"Cesedi ta\u015fa sar\u0131l\u0131p K\u0131z\u0131l\u0131rmak'a at\u0131lm\u0131\u015ft\u0131... 2 caniye ceza ya\u011fd\u0131!","updatedDateTime":"2026-01-19 15:09:13","updatedDateTimeFormatted":"3 saat \u00f6nce","urlTarget":"_blank","updatedElapsedTimeFormatted":"4 saat \u00f6nce","image":{"imageUrlBase":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768820616\/3854563\/jpg\/","imageUrlHeadlineDesktop":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768820616\/3854563_manset\/jpg\/640x640","imageUrlHeadlineMobile":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768820616\/3854563_manset\/jpg\/414x414","showHeadlineTitle":false,"title":"","ratio":{"width":1,"height":1}},"lastMinuteNews":false,"gtmTracker":{"class":"gtm-tracker","dataAttr":"data-newslist=\"sidebar\" data-newsposition=\"15\" data-newsid=\"3854563\" data-newsname=\"Cesedi ta\u015fa sar\u0131l\u0131p K\u0131z\u0131l\u0131r