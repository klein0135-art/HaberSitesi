g:\/\/haber\/kategori\/ekonomi\/anasayfa"},{"id":4060556,"name":"\u0130\u015f-Ya\u015fam","url":"\/ekonomi\/is-yasam","appUrl":"cbg:\/\/haber\/kategori\/ekonomi\/is-yasam"}]},"url":"\/cumhurbaskani-erdogan-dan-aciklamalar-3854571-ekonomi","appUrl":"cbg:\/\/haber\/detay\/3854571","ampUrl":"\/cumhurbaskani-erdogan-dan-aciklamalar-3854571-amp","newsMetaData":{"textColor":"text-white","appTextColor":"white","newsDetailType":"type1","headline":"","emoji":0,"specialColor":"","specialColorText":""},"fastLinkText":"Esenbo\u011fa'da 3. pist ve yeni kule a\u00e7\u0131ld\u0131","updatedDateTime":"2026-01-19 14:47:40","updatedDateTimeFormatted":"3 saat \u00f6nce","urlTarget":"_blank","updatedElapsedTimeFormatted":"4 saat \u00f6nce","image":{"imageUrlBase":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768823244\/3854571\/jpg\/","imageUrlHeadlineDesktop":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768823244\/3854571_manset\/jpg\/640x640","imageUrlHeadlineMobile":"https:\/\/im.haberturk.com\/l\/2026\/01\/19\/ver1768823244\/3854571_manset\/jpg\/414x414","showHeadlineTitle":false,"title":"","ratio":{"width":1,"height":1}},"lastMinuteNews":false,"gtmTracker":{"class":"gtm-tracker","dataAttr":"data-newslist=\"sidebar\" data-newsposition=\"49\" data-newsid=\"3854571\" data-newsname=\"Esenbo\u011fa'da 3. pist ve yeni kule a\u00e7\u0131ld\u0131\" data-newsvariant=\"news\" data-newscategory=\"Ekonomi\""}},{"newsId":3854637,"type":"news","title":"19 Ocak 2026: Bug\u00fcn ne oldu?","spot":"Siyasetten spora, magazinden ekonomiye... T\u00fcrkiye'de ve d\u00fcnyada \u00f6ne \u00e7\u0131kan ba\u015fl\u0131klar\u0131, g\u00fcn\u00fcn ka\u00e7\u0131r\u0131lmamas\u0131 gereken haberlerini Helin Gen\u00e7, Haberturk.com Haber Merkezi'ne soruyor. \u0130\u015fte 19 Ocak 2026'n\u0131n \u00f6ne \u00e7\u0131kan haberleri...\n\n* T\u00fcrkiye genelinde kar ya\u011f\u0131\u015f\u0131 etkili oldu. \u0130stanbul Valili\u011fi'nce, yar\u0131n sabah saat 10.00'a kadar kuryelerin trafi\u011fe \u00e7\u0131k\u0131\u015f\u0131 yasakland\u0131\n\n* Gr\u00f6nland'\u0131n ABD'ye ait olmas\u0131 gerekti\u011fi y\u00f6n\u00fcndeki a\u00e7\u0131klamalar\u0131n\u0131 yineleyen ABD Ba\u015fkan\u0131 Trump, Norve\u00e7 Ba\u015fbakan\u0131 Store'a mektup g\u00f6ndererek \"Art\u0131k sadece bar\u0131\u015f\u0131 d\u00fc\u015f\u00fcnmek zorunda hissetmiyorum, art\u0131k Amerika Birle\u015fik Devletleri i\u00e7in neyin iyi ve do\u011fru oldu\u011funu d\u00fc\u015f\u00fcnebilirim\" dedi\n\n* Ankara Esenbo\u011fa Havaliman\u0131'nda 3. pist, yeni kule ve tamamlay\u0131c\u0131 tesisler Cumhurba\u015fkan\u0131 Erdo\u011fan'\u0131n kat\u0131ld\u0131\u011f\u0131 t\u00f6renle a\u00e7\u0131ld\u0131\n\n* Noa Lang ad\u0131m ad\u0131m Galatasaray'a: Prensip anla\u015fmas\u0131na var\u0131ld\u0131!\n\n* Ye\u015fil\u00e7am'\u0131n emektar isimlerinden Necdet K\u00f6ke\u015f, 27 Aral\u0131k 2025'te ge\u00e7irdi\u011fi kalp krizi nedeniyle tedavisi yo\u011fun bak\u0131mda devam ediyordu. 81 ya\u015f\u0131ndaki K\u00f6ke\u015f'in sa\u011fl\u0131k durumunun kritik oldu\u011fu a\u00e7\u0131kland\u0131\n","slug":"19-ocak-2026-bugun-ne-oldu-iste-gunun-one-cikan-haberleri","writer":"","category":{"type":"category","items":[{"id":110,"name":"G\u00fcndem","url":"\/gundem","appUrl":"cbg:\/\/haber\/kategori\/ht\/gundem"}]},"url":"\/video\/haber\/izle\/19-ocak-2026-bugun-ne-oldu-iste-gunun-one-cikan-haberleri\/900274","appUrl":"cbg:\/\/video\/detay\/900274","ampUrl":"\/video\/haber\/izle\/19-ocak-2026-bugun-ne-oldu-iste-gunun-one-cikan-haberleri\/900274","newsMetaData":{"textColor":"text-white","appTextColor":"white","newsDetailType":"type1","headline":"","emoji":0,"specialColor":"","specialColorText":""},"fastLinkText":"19 Ocak 2026: Bug\u00fcn ne oldu? \u0130\u015fte g\u00fcn\u00fcn \u00f6ne \u00e7\u0131kan haberleri","updatedDateTime":"2026-01-19 17:23:15","updatedDateTimeFormatted":"1 saat \u00f6nce","urlTarget":"_blank","updatedElapsedTimeFormatted":"1 saat \u00f6nce","image":{"imageUrlBase":"http