emius_pending('gemius_event'); gemius_pending('pp_gemius_hit'); gemius_pending('pp_gemius_event'); (function(d, t) { try { var gt = d.createElement(t), s = d.getElementsByTagName(t)[0], l = 'http' + ((location.protocol === 'https:') ? 's' : ''); gt.setAttribute('async', 'async'); gt.setAttribute('defer', 'defer'); gt.src = l + '://tr.hit.gemius.pl/xgemius.js'; s.parentNode.insertBefore(gt, s); } catch (e) {} })(document, 'script'); }, 100); </script>       <script> var __OGEZIO_ASYNC_OPTIONS = { "m1": 100, "m2": 1, "m3": 110, "i1": 3854645, "i2": 0, "i3": 0, "keywords": "Cumhurbaşkanı Erdoğan, kabine toplantısı, haberler" }; </script>                         <script type="application/ld+json"> { "@context": "https://schema.org", "@type": "NewsArticle", "articleSection": "Gündem", "mainEntityOfPage": { "@type": "WebPage", "@id": "https://www.haberturk.com/cumhurbaskani-recep-tayyip-erdogan-teror-donemi-tamamen-kapanmistir-3854645" }, "headline": "Cumhurbaşkanı Recep Tayyip Erdoğan: Terör dönemi tamamen kapanmıştır", "alternativeHeadline": "Cumhurbaşkanı Recep Tayyip Erdoğan: Terör dönemi tamamen kapanmıştır", "description": "Kabine toplantısı sonrası konuşan Cumhurbaşkanı Erdoğan, “Suriye ile çok yakından ilgileniyoruz” diyerek bölgedeki barış ve entegrasyon sürecine destek verdi; “Bölgemizde terörün devri tamamen kapanmıştır” mesajıyla birlik ve huzur vurgusu yaptı ve Atlas yavrumuzu katledenlerin hukuk önünde en ağır cezayı alması için sürecin sıkı takipçisi olacaklarını açıkladı.", "articleBody": "Cumhurbaşkanlığı Kabine Toplantısı sona erdi. Toplantının ardından kameraların karşısına &amp;ccedil;ıkan Cumhurbaşkanı Recep Tayyip Erdoğan dan a&amp;ccedil;ıklamalar...   Cumhurbaşkanı Erdoğan ın a&amp;ccedil;ıklamalarından &amp;ouml;ne &amp;ccedil;ıkan başlıklar ş&amp;ouml;yle:   86 MİLYONA MAH&amp;Ccedil;UP OLMADIK  Dış politikadan ticarete, ekonomiden g&amp;uuml;venliğe, &amp;uuml;lkemizin ve b&amp;ouml;lgemizin g&amp;uuml;ndeminde yer alan konuları değerlendirdiğimiz toplantımızın hayırlara vesile olmasını Rabbimden niyaz ediyorum. 86 milyonun emanetini taşıyan kadro olarak bizim i&amp;ccedil;in &amp;ouml;nemli olan aziz milletimizin, T&amp;uuml;rkiye nin huzuru, esenliği, refahı, geleceğine g&amp;uuml;venle umutla bakmasıdır. Hep bu anlayışla &amp;ccedil;alıştık. Milletimizin tevecc&amp;uuml;h&amp;uuml;ne layık olabilmek adına gece g&amp;uuml;nd&amp;uuml;z demeden koşturduk. 86 milyona mah&amp;ccedil;up olmadık. T&amp;uuml;rkiye nin menfaatlerini her zaman g&amp;uuml;ndemimizin ilk sırasına yerleştirdik. Herşeyi g&amp;ouml;ze alarak bunları sonuna kadar savunduk. Biz şeffaflığı dillerinden d&amp;uuml;ş&amp;uuml;rmeyenlerin aksine aynı zamanda millete hesap vermeyi şiar edinmiş kadroyuz. 2025 yılına ait hizmet d&amp;ouml;k&amp;uuml;m&amp;uuml;m&amp;uuml;z&amp;uuml;n &amp;ouml;zetini ge&amp;ccedil;tiğimiz g&amp;uuml;nlerde kamuoyumuzla paylaştık. &amp;Ccedil;ocuklarımızın yarı yıl karne heyecanını yaşadığı şu g&amp;uuml;nlerde biz de ge&amp;ccedil;en seneye ait karnemizi aziz milletimizin takdirine sunduk.   HER İNSANIMIZI AYNI MUHABBETLE BAĞRIMIZA BASIYORUZ  T&amp;uuml;rkiye yi her alanda coşturmak, şaha kaldırmak, kutlu hedeflerine bir adım daha yaklaştırmak i&amp;ccedil;in t&amp;uuml;m imkanlarımızı seferber etmiş durumundayız. Vatanın her k&amp;ouml;şesini ihya etmek, bu &amp;uuml;lkenin imkanlarını her ferde adil şekilde ulaştırmakta kararlıyız. Bize oy vermiş ya da vermemiş vatandaşlarımın şunu &amp;ccedil;ok iyi bilmesini arzu ediyorum. 81 ilimizde yaşayan her bir kardeşimiz bizim nazarımızda aynı standartta h&amp;uuml;rmete layıktır. Oy tercihlerine g&amp;ouml;re insanlarımızı ayırmak bizim kitabımızda hi&amp;ccedil;bir zaman yer almamıştır. Her insanımızı aynı muhabbetle bağrımıza basıyoruz. Biz her zaman eserlerimizle konuşuyoruz. Bug&amp;uuml;n başkentimiz Ankara ya yeni T&amp;uuml;rkiye yi simgeleyen bir yatırımı kazandırmanın gururunu yaşadık. Hizmete a&amp;ccedil;tığımız Esenboğa Havalimanı 3. pistinin ve kulesinin hayırlı uğurlu olmasını temenni ediyorum. T&amp;uuml;rkiye nin başşehrini vatandaşlarımızı haftalarca susuzluğa mahkum edenlerin zihniyetin insafına bırakamayız. Kendileri dışındaki herkesi su&amp;ccedil;lamaya, basın mensuplarını tehdit edenler bizim hizmet şevkimizi kıramazlar. Bu &amp;uuml;lkede kutuplaştırma deyince, kriz fırsat&amp;ccedil;ılığı deyince, felaket tellallığı, işbilmezlik deyince kimin akla geldiği herkesin malumudur. Kimin hizmet karnesinin pekiyilerle dolu, kimin sicilinin zayıf ve kara lekelerle dolu olduğu gayet bellidir.  BU G&amp;Uuml;VENİ ASLA BOŞA &amp;Ccedil;IKARMAYACAĞIZ  &amp;Ouml;zellikle yerel y&amp;ouml;netim d&amp;uuml;zeyinde patlak veren skandallar T&amp;uuml;rkiye nin son genel se&amp;ccedil;imlerde ne kadar isabetli tercih yaptığını ortaya koyuyor. 14-28 Mayıs se&amp;ccedil;imlerinde milletimiz derin bir u&amp;ccedil;urumun kıyısından son anda d&amp;ouml;nm&amp;uuml;ş, T&amp;uuml;rkiye b&amp;uuml;y&amp;uuml;k bir vartayı atlatmıştır. Milletimiz iktidar ve ittifakımıza g&amp;uuml;venerek birilerinin yanlış anladığı Anodolu irfanının ne demek olduğunu sandıkta bir kez daha g&amp;ouml;stermiştir. Tercihini bizden yana kullanan yaklaşık 28 milyon kardeşimizin yanısıra sandığa iradesini farklı şekilde yansıtan vatandaşlarımız da T&amp;uuml;rkiye nin kaptan k&amp;ouml;şk&amp;uuml;nde bizlerin olmasından dolayı hamd ediyor, coğrafyamızı kuşatan krizlere baktığında kendini g&amp;uuml;vende hissediyor. 86 milyonun tamamına teşekk&amp;uuml;r ediyorum. İnsanlarımız bize inanmaya, g&amp;uuml;venmeye devam etsin. İnşallah biz bu g&amp;uuml;veni asla ve asla boşa &amp;ccedil;ıkarmayacağız. Bizi &amp;ccedil;ekmek istedikleri suni ve sanal tartışmalara girmeyecek, vaktimizi 86 milyonun ekmeğini b&amp;uuml;y&amp;uuml;tmek, hizmet ve eser &amp;uuml;retmek i&amp;ccedil;in kullanacağız.  ULUSLARARASI SİSTEM YARA ALDI  Bug&amp;uuml;nk&amp;uuml; kabine toplantımızda dış siyasi gelişmeleri etraflıca istişare ettik. T&amp;uuml;rkiye nin bu fırtınalı d&amp;ouml;nemi kazasız, belasız atlatması i&amp;ccedil;in ilave tedbirleri g&amp;ouml;r&amp;uuml;şt&amp;uuml;k. Mevcut sorunlar b&amp;uuml;y&amp;uuml;rken bunlara herg&amp;uuml;n yenileri ekleniyor. Kural temelli uluslararası sistem hem &amp;ccedil;ok ağır yara aldı hem de ciddi itibar kaybına uğradı. Hukukun g&amp;uuml;c&amp;uuml; yerine g&amp;uuml;&amp;ccedil;l&amp;uuml;n&amp;uuml;n hukukunun egemen olduğu adaletsiz ve &amp;ccedil;arpık k&amp;uuml;resel d&amp;uuml;zene doğru hızla s&amp;uuml;r&amp;uuml;kleniyoruz.  İLKELİ BİR TUTUM İZLEDİK  Rusya-Ukrayna savaşında her iki tarafta y&amp;uuml;zbinlerce insan &amp;ouml;ld&amp;uuml;. Pek&amp;ccedil;ok kişi doğduğu toprakları terk etmek zorunda kaldı. Barış umutlarını artıracak yol haritası maalesef hen&amp;uuml;z oluşmadı. Komşumuz İran, İsrail saldırılarından sonra şimdi de toplumsal huzurunu ve istikrarını hedef alan yeni sınamayla karşı karşıya. Diyaloğu ve diplomasiyi &amp;ouml;nceleyen ince bir siyasetle İranlı kardeşlerimiz tuzaklarla dolu bu d&amp;ouml;nemi inşallah geride bırakacaklarına inanıyoruz. Barışı ve istikrarı merkeze alan dış politikamızla b&amp;ouml;lgemizi belirsizliğe s&amp;uuml;rekleme riski olan her t&amp;uuml;rl&amp;uuml; girişimin karşısında olacağız. Bize g&amp;ouml;re her t&amp;uuml;rl&amp;uuml; sorunun &amp;ccedil;&amp;ouml;z&amp;uuml;m adresi karşılıklı g&amp;uuml;ven ilişkisine dayalı m&amp;uuml;zakere masasıdır. İlgili t&amp;uuml;m tarafları aklı selime, diyaloğa ve diplomasiye davet ediyor, tansiyonu d&amp;uuml;ş&amp;uuml;rme noktasında bize d&amp;uuml;şen ne varsa yapmaya hazır olduğumuzu bilinmesini istiyorum.  SURİYE İLE &amp;Ccedil;OK YAKINDAN İLGİLENİYORUZ  Ortak tarih ve k&amp;uuml;lt&amp;uuml;r&amp;uuml;, medeniyeti paylaştığımız Suriye deki her gelişmeyle &amp;ccedil;ok yakında ilgileniyoruz. Suriye nin 8 Aralık devrimiyle kavuştuğu &amp;ouml;zg&amp;uuml;rl&amp;uuml;k ortamını kalıcı huzura, barışa tahvil edilmesi i&amp;ccedil;in yoğun &amp;ccedil;aba harcıyoruz. Bir ve beraber Suriye nin vazge&amp;ccedil;ilmez olduğu inancındayız. Suriye Suriyelilerindir. Suriye Arap, T&amp;uuml;rkmen, K&amp;uuml;rt, Nusayri, Sunni, D&amp;uuml;rzi demeden herkesindir. T&amp;uuml;m kesimleriyle kardeş Suriye halkınındır. Y&amp;uuml;zbinlerce insanın hayatına malolan zulm&amp;uuml;n ardından Suriye tarihi bir fırsat yakalamıştır. Suriyeli kardeşlerimizin &amp;ouml;n&amp;uuml; de ufku da bahtı da a&amp;ccedil;ıktır. Suriye halkının kardeşi, komşusu, kara g&amp;uuml;n dostu &amp;uuml;lke olarak bunu sabote edecek hi&amp;ccedil;bir teşebb&amp;uuml;se m&amp;uuml;saade etmeyiz. Tek devlet, tek ordu ilkesi bir &amp;uuml;lkede istikrarın olmazsa olmaz şartıdır. Bunu tahkim edecek her t&amp;uuml;rl&amp;uuml; adıma T&amp;uuml;rkiye nin desteği tamdır. Halep in bazı mahallelerin işgalden kurtarılması adına başlatılan harekat d&amp;uuml;n ateşkes ve tam entegrasyon anlaşmasıyla sonu&amp;ccedil;landı. Suriye ordusunun bu hassas operasyonu dikkatle y&amp;ouml;netmesi operasyon s&amp;uuml;recinde sivillerin zarar g&amp;ouml;rmemesi i&amp;ccedil;in cerrah titizliğinde hareket etmesi her t&amp;uuml;rl&amp;uuml; takdire şayandır. Suriye nin kuzeyini işgal altında tutan silahlı unsurların provokasyonlarına rağmen Suriye ordusu başarılı sınav vermiş. Haklı iken haksız duruma d&amp;uuml;şecek eylemlerden ka&amp;ccedil;ınmıştır. Suriye h&amp;uuml;k&amp;uuml;meti en az hasarla &amp;ccedil;&amp;ouml;z&amp;uuml;me kavuşturmuştur. T&amp;uuml;m bunların &amp;ccedil;ok kıymetli kazanımlar olduğuna inanıyoruz. D&amp;uuml;n akşam Cumhurbaşkanı Ahmet Şara kardeşimle telefon g&amp;ouml;r&amp;uuml;şmesi ger&amp;ccedil;ekleştirdik. Kendisini anlaşma ve operasyondan &amp;ouml;t&amp;uuml;r&amp;uuml; tebrik ettim. DEAŞ başta olmak &amp;uuml;zere ter&amp;ouml;re karşı m&amp;uuml;cadelelerinde T&amp;uuml;rkiye nin daima yanında olduğunu bir kez daha ifade ettim. Suriye halkını d&amp;uuml;n olduğu gibi inşallah yarın da yalnız bırakmayacağız. Devlet i&amp;ccedil;inde devlet kurma peşinde koşan bir avu&amp;ccedil; taşeron dışında Suriye halkının d&amp;uuml;nk&amp;uuml; anlaşmadan b&amp;uuml;y&amp;uuml;k sevin&amp;ccedil; duyduğu anlaşılıyor. Halep, Rakka, Deyr Zor ve diğer şehirlerin sokaklarından yansıyan fotoğraflar barış &amp;ouml;zlemini g&amp;ouml;steriyor. 13,5 yıl boyunca b&amp;uuml;y&amp;uuml;k acılar &amp;ccedil;eken halk umudu yeniden kuşanmakta, hayata yeniden sarılmakta, artık savaş istemediğini a&amp;ccedil;ık&amp;ccedil;a beyan etmektedir. Kimsenin bunu g&amp;ouml;rmezden gelme hele hele bu umut iklimini dinamitleme hakkı yoktur. Suriye nin bereketli toprakları acıya, kana, g&amp;ouml;zyaşına doymuştur.  T&amp;Uuml;M HALKLARA KOLLARIMIZI VE KALBİMİZİN KAPILARINI ARDINA KADAR A&amp;Ccedil;TIK  İpe un sermenin, ayak diremenin &amp;ccedil;eşitli bahanelerin arkasına saklanarak zamana oynamanın kimseye faydası olmaz. B&amp;ouml;lgemizde ter&amp;ouml;r&amp;uuml;n devri tamamen kapanmıştır. Ateşkes ve tam entegrasyon anlaşmasının gerekleri s&amp;uuml;ratle yerine getirilmelidir. Biz &amp;ccedil;ıkar hesabıyla değil insani hassasiyetlerle yol y&amp;uuml;r&amp;uuml;yen bir iktidarız. Bug&amp;uuml;ne kadar attığımız her adımda değerlerimizi kuşandık, ilkelerimizi g&amp;ouml;z ettik. T&amp;uuml;m halklara kollarımızı ve kalbimizin kapılarını ardına kadar a&amp;ccedil;tık. Irk&amp;ccedil;ılık ve kavmiyet&amp;ccedil;ilik bizim kadim k&amp;uuml;lt&amp;uuml;r&amp;uuml;m&amp;uuml;z&amp;uuml;n, bizim medeniyetimizin, inan&amp;ccedil; değerlerimizin reddettiği hastalıktır.  KURDUĞUMUZ DEVLETLERİN TAMAMI IRK&amp;Ccedil;ILIĞIN REDDİ &amp;Uuml;ZERİNE BİNA EDİLMİŞTİR  Bunların hi&amp;ccedil;biri bizim kitabımızda yoktur. Kurduğumuz devletlerin tamamı ırk&amp;ccedil;ılığın reddi &amp;uuml;zerine bina edilmiştir. Sel&amp;ccedil;uklu, Osmanlı, T&amp;uuml;rkiye Cumhuriyeti bu tasavvur ve tahayy&amp;uuml;l etrafında şekil kazanmıştır. Biz de T&amp;uuml;rk, K&amp;uuml;rt, Arap derken bu anlayışla hareket ediyoruz. T&amp;uuml;rkiye hi&amp;ccedil;bir mezhebin, etnik kimliğin karşısında değildir. &amp;Ccedil;atışmalar &amp;uuml;zerinden g&amp;uuml;&amp;ccedil; ve rant devşirmek gibi ucuz ve vicdansız hesabın i&amp;ccedil;inde değildir. Biz artık kardeşlik zemininde aklı selimle &amp;ccedil;&amp;ouml;z&amp;uuml;lmesini savunan &amp;uuml;lkeyiz. Aralarında kimi siyaset&amp;ccedil;ilerin kimi yazarların kimi milletvekillerinin de olduğu &amp;ccedil;evrelerin ırk&amp;ccedil;ılık vir&amp;uuml;s&amp;uuml;n&amp;uuml; kaptıklarını &amp;uuml;z&amp;uuml;lerek g&amp;ouml;r&amp;uuml;yoruz. Hangi vicdan sahibi zorla ailelerinden kopartılan, dağa ka&amp;ccedil;ırılan &amp;ccedil;ocuklarının &amp;ouml;l&amp;uuml;me g&amp;ouml;nderilmesini savunabilir. Şehirleri işgal edip, sivil halka eziyet etmeyi kim makul g&amp;ouml;r&amp;uuml;lebilir. Halep in şen olması, b&amp;uuml;t&amp;uuml;n mahallleri ile g&amp;uuml;venli hale gelmesi kimi ni&amp;ccedil;in rahatsız eder? Ellerine boylarından b&amp;uuml;y&amp;uuml;k silah tutuşturulan o &amp;ccedil;ocuklar, intihar yelekleri giydirilen o &amp;ccedil;ocuklar hem K&amp;uuml;rt kardeşlerimizin hem Suriye nin geleceği değil mi? Ter&amp;ouml;rle, şiddetle hi&amp;ccedil;bir yere varılamayacağının anlaşılması i&amp;ccedil;in daha ka&amp;ccedil; &amp;ccedil;ocuğun &amp;ouml;lmesi lazım? Arabın kanı K&amp;uuml;rde, K&amp;uuml;rd&amp;uuml;n kanı T&amp;uuml;rk e, T&amp;uuml;rkmen e haram değil mi? K&amp;uuml;rt, Arap bizim kardeşimiz. T&amp;uuml;rkmen, Sunni, Şii, Alevi bizim canımız, ciğerimiz, can kardeşimiz değil mi? Meselelerimizi &amp;ccedil;&amp;ouml;z mek varken bu nefret, &amp;ouml;fke, hırs, hın&amp;ccedil; ve ihtiras niye. T&amp;uuml;rkiye Cumhuriyeti burada iken bu devlet Allah a hamdolsun dimdik ayakta iken neden başka hamiler, dostlar, yoldaşlar, ortaklar aranıyor, ni&amp;ccedil;in elinde m&amp;uuml;sl&amp;uuml;man kanı olanlardan medet umuluyor? Bu topraklarda kesret i&amp;ccedil;inde vahdet olmak dururken ni&amp;ccedil;in ayrışıyoruz?  HEP BERABER YAN YANA HUZUR İ&amp;Ccedil;İNDE YAŞAYALIM İSTİYORUZ  Olaylara vicdan penceresi yerine ırk&amp;ccedil;ılık ve kavmiyet&amp;ccedil;ilik g&amp;ouml;zl&amp;uuml;ğ&amp;uuml;nden bakanları bu hatadan d&amp;ouml;nmeye &amp;ccedil;ağırıyorum. Biz bu coğrafyanın bin yıllık sakin ve sahipleriyiz. Bizim T&amp;uuml;rk, K&amp;uuml;rt, Arap olarak birbirimizden başka dostumuz, yoldaşımız, dar g&amp;uuml;n&amp;uuml;m&amp;uuml;zde kapısını &amp;ccedil;alacağımız sığınağımız yok. Bu b&amp;ouml;lgede ne zaman birbirimize kardeş&amp;ccedil;e, dost&amp;ccedil;a muamele ettiysek o zaman b&amp;uuml;y&amp;uuml;d&amp;uuml;k, g&amp;uuml;&amp;ccedil;lendik, aşılmaz kale olduk. Ne zamanki T&amp;uuml;rk, K&amp;uuml;rt, Arap, Şi, Sunni birbirimize d&amp;uuml;şt&amp;uuml;k o zaman zayıfladık, kaybettik. Acı &amp;ccedil;ektik. Biz Suriye başta olmak &amp;uuml;zere coğrafyamızın hi&amp;ccedil;bir k&amp;ouml;şesinde artık savaş, &amp;ccedil;atışma, gerilim g&amp;ouml;rmek istemiyoruz. Yeraltı ve yer &amp;uuml;st&amp;uuml; zenginliklerimizin savaş baronlarının ceplerine akmasını istemiyoruz. Kardeşlerimiz a&amp;ccedil;lık, kıtlık, yoksullukla boğuşurken bir damla petrol&amp;uuml; oluk oluk akan insan kanından değerli g&amp;ouml;ren materyalist zihniyetin palazlanmasını istemiyoruz. Hep birlikte kazanalım istiyoruz. Barışın ve istikrarın egemen olduğu b&amp;ouml;lgede hep beraber yanyana, huzur i&amp;ccedil;inde yaşayalım istiyoruz.  ATLAS I &amp;Ouml;LD&amp;Uuml;RENLER CEZASINI ALMALI  Etnik k&amp;ouml;ken, din, mezhebine bakmaksızın b&amp;ouml;lgede akan kanın durması, &amp;ouml;l&amp;uuml;mlerin, katliamların son bulmasını istiyoruz. &amp;Ouml;zellikle de Atlas yavrumuzu katleden canilerin burada &amp;ouml;zellikle yargıda gereken dersi almasını istiyoruz. Ve bu konuda ilgili olarak da &amp;uuml;zerimize d&amp;uuml;şen g&amp;ouml;rev neyse sonuna kadar yerine getirmenin ahdi ve kararlılığı i&amp;ccedil;erisinde olduğumuzu da s&amp;ouml;ylemek istiyorum. Minguzzi olayı neyse Atlas yavrumuzun olayı da en az onun kadar bizi acılara boğmuştur. Bunlar kabul edilebilir şeyler değil Ne gerekiyorsa başta Adalet Bakanımız olmak &amp;uuml;zere, yargının t&amp;uuml;m kurumları, İ&amp;ccedil;işleri Bakanlığı b&amp;uuml;t&amp;uuml;n bunların &amp;uuml;zerine gitmek suretiyle gereğini yapmak bizim g&amp;ouml;revimizdir. O pırlanta gibi yavru, o kadar g&amp;uuml;zelimsi yavru nasıl acımasızca katledilir? Bunun hesabını sormak g&amp;ouml;revimizdir. T&amp;uuml;rk, K&amp;uuml;rt, Arap, S&amp;uuml;nni, Şii ayrımı yapmaksızın bir, iri, diri olmayı istiyor ve gayret g&amp;ouml;steriyoruz. Ter&amp;ouml;rs&amp;uuml;z T&amp;uuml;rkiye s&amp;uuml;recimizin gayesi, hedefi, menzili budur. Ter&amp;ouml;rs&amp;uuml;z b&amp;ouml;lge idealinin altını &amp;ccedil;izmemizin sebebi ayrıca budur. Menzile ulaşmak Cenab-ı Allah ın takdirindedir. İktidar ve ittifak olarak bu gayeyle &amp;ccedil;alışmaya, sağduyulu yaklaşım i&amp;ccedil;inde olmayı kararlılıkla devam ettireceğiz. Bizi b&amp;ouml;lmek, par&amp;ccedil;alamak, birbirimize d&amp;uuml;şman eylemeyi isteyenlere inat omuz omuza y&amp;uuml;reyeceğiz. &amp;Ouml;nce &amp;uuml;lkemizi ardından da b&amp;ouml;lgemizi ter&amp;ouml;r&amp;uuml;n kanlı pen&amp;ccedil;esinden inşallah ebediyyen kurtaracağız. Bunu da muhabbet ve dayanışma i&amp;ccedil;inde uhuvvet ve vahdet i&amp;ccedil;inde hep birlikte başaracağız. Rabbim y&amp;acirc;r ve yardımcımız olsun diyorum. Kabine toplantımızda aldığımız kararların &amp;uuml;lkemiz ve b&amp;ouml;lgemiz i&amp;ccedil;in hayırlara vesile olmasını temenni ediyorum. Sizleri sevgi ve saygıyla selamlıyorum. Allah a emanet ediyorum, kalın sağlıcakla.", "wordCount": "1559", "genre":"news", "dateCreated": "2026-01-19T18:43:38+03:00", "datePublished": "2026-01-19T18:43:38+03:00", "dateModified": "2026-01-19T19:37:05+03:00", "keywords": [ "Cumhurbaşkanı Erdoğan, kabine toplantısı, haberler" ], "typicalAgeRange":"7-", "isFamilyFriendly":"http://schema.org/True", "image": { "@type": "ImageObject", "url": "https://im.haberturk.com/l/2026/01/19/ver1768840624/3854645/jpg/19